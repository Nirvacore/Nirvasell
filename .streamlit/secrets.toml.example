# Streamlit secrets — copy to `.streamlit/secrets.toml` (gitignored)
#
# Used in two situations:
#   1. Streamlit Cloud deploys (UI: Advanced settings → Secrets)
#   2. Native OAuth via st.login() (requires Streamlit 1.42+)
#
# For self-hosted Docker, prefer `.env` instead — easier to manage with
# `--env-file` and `docker compose`.

ANTHROPIC_API_KEY = "sk-ant-..."


# =====================================================================
# Native OAuth — Google / Apple / Microsoft (Streamlit 1.42+)
# =====================================================================
# Streamlit's built-in OIDC integration. Configure any provider here and a
# "Sign in with X" button appears on the login screen automatically.
#
# Each section is independent — comment out the ones you don't use.

[auth]
# Where Streamlit's auth UI redirects back to after the provider login.
# Must match exactly what you registered with the provider.
# For local dev: http://localhost:8501/oauth2callback
# For prod:     https://nirva.example.com/oauth2callback
redirect_uri = "http://localhost:8501/oauth2callback"

# A long random string. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
cookie_secret = "REPLACE_ME_WITH_A_LONG_RANDOM_STRING"


# ----- Google -----
# 1. https://console.cloud.google.com → Create project
# 2. APIs & Services → Credentials → Create OAuth client ID → Web app
# 3. Authorized redirect URI = the redirect_uri above
# 4. Paste the client ID + secret here
[auth.google]
client_id = "..."
client_secret = "..."
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"


# ----- Apple -----
# Requires Apple Developer account ($99/yr).
# 1. https://developer.apple.com → Certificates → Identifiers → +
# 2. App ID + Services ID (the Services ID is your "client_id")
# 3. Sign in with Apple capability → Web Domain + return URL = redirect_uri
# 4. Create a "Sign in with Apple" key, download the .p8 file
# 5. Build a client_secret JWT signed with that key — refresh every 6 months
#    See: https://developer.apple.com/documentation/sign_in_with_apple/generate_and_validate_tokens
[auth.apple]
client_id = "com.example.nirva.web"
client_secret = "<JWT signed with your .p8 key>"
server_metadata_url = "https://appleid.apple.com/.well-known/openid-configuration"


# ----- Microsoft -----
# 1. https://portal.azure.com → Azure AD → App registrations → New
# 2. Redirect URI (web) = the redirect_uri above
# 3. Certificates & secrets → New client secret
[auth.microsoft]
client_id = "..."
client_secret = "..."
# `common` = any account (work, school, personal). Replace with a tenant ID
# to limit to one organization.
server_metadata_url = "https://login.microsoftonline.com/common/v2.0/.well-known/openid-configuration"
