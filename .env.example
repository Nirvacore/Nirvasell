# nirva.sell — environment template
#
# Copy this file to `.env` and fill in values. Never commit `.env` itself.
#   cp .env.example .env
#
# Everything below is optional — nirva.sell runs without any of it set.
# Users can also paste their API keys in the UI at runtime; env vars are
# the recommended path for headless / production deploys.

# ====================================================================
# AI — Anthropic Claude
# ====================================================================
# Get one at https://console.anthropic.com  (starts with `sk-ant-...`)
# Each user enters their own in the UI by default; set this if you want a
# shared org-wide fallback (not recommended for SaaS — costs add up).
ANTHROPIC_API_KEY=

# ====================================================================
# Payments — PromptPay (Thailand) + Stripe (global)
# ====================================================================
# Phone number (10 digits, e.g. 0812345678) OR national ID (13 digits).
# Used to generate a per-amount PromptPay QR — no fees, no API account.
PROMPTPAY_ID=
PROMPTPAY_NAME=

# Stripe Payment Link — create one at
# https://dashboard.stripe.com/payment-links  (a single URL, no SDK needed)
STRIPE_PAYMENT_LINK=

# Optional donation outlets
BUYMEACOFFEE_URL=
GITHUB_SPONSORS_URL=

# ====================================================================
# Cloudinary — public image hosting for product photos (free tier)
# ====================================================================
# Get keys at https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ====================================================================
# Notifications — fan-out channels for policy/order/batch events
# ====================================================================
# SMTP (email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Telegram bot — create one via @BotFather, get the token + your chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# LINE Notify — get a token at https://notify-bot.line.me
LINE_NOTIFY_TOKEN=

# Generic webhook — Slack incoming webhook, Discord, Zapier, anything
WEBHOOK_URL=

# ====================================================================
# Supplier scrapers (used by the reseller/ project, not nirva itself)
# ====================================================================
# Synnex dealer portal (synnex.co.th/dealer)
SYNNEX_USER=
SYNNEX_PASS=

# VSTECS online (online.vstecs.co.th)
VSTECS_USER=
VSTECS_PASS=

# Integra Re solar shop (solarshop.integra-re.co.th)
SOLAR_USER=
SOLAR_PASS=

# ====================================================================
# Auth — magic-link email login
# ====================================================================
# Public URL of your deployment — used inside emailed magic links.
# Defaults to http://localhost:8501 for dev.
APP_URL=

# OAuth (Google / Apple / Microsoft) is configured in
# .streamlit/secrets.toml rather than here — see that file's example.

# ====================================================================
# Defaults
# ====================================================================
MARKUP_PERCENT=15
ROUND_TO=10
