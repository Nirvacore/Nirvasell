{
  "schema_version": "1.0",
  "description": "Universal ERP Mapping — links enterprise functional modules to the controls, taxonomy domains and standards they operationalize. This is how the knowledge graph plugs into an operating ERP/business system (the Nirva product family). `controls` references controls.json; `domains` references taxonomy.json; `standards` references standards.json.",
  "modules": [
    {"module": "Governance / GRC", "domains": ["L1","L2","L3","L18"], "controls": ["UC-RM","UC-AUD","UC-DOC"], "standards": ["COBIT","ISO37301","COSOIC","ISO38500"], "data_objects": ["policy","risk","control","audit","obligation"]},
    {"module": "Human Resources (HR/HCM)", "domains": ["L4","L11","L15"], "controls": ["UC-TRN","UC-OHS","UC-AC"], "standards": ["ISO30414","ISO45001","ISO9001","GDPR"], "data_objects": ["employee","competency","training","role","incident"]},
    {"module": "Finance & Accounting", "domains": ["L5","L3","L18"], "controls": ["UC-FIN","UC-AUD","UC-AC"], "standards": ["COSOIC","SOX","SOC1","IFRS_ACC"], "data_objects": ["ledger","reconciliation","approval","journal"]},
    {"module": "Procurement / Supply Chain", "domains": ["L9","L2","L20"], "controls": ["UC-SUP","UC-RM","UC-DOC"], "standards": ["ISO37001","NIST800171","DORA","ISO9001"], "data_objects": ["vendor","contract","DPA","assessment","PO"]},
    {"module": "Quality Management", "domains": ["L6","L16","L8"], "controls": ["UC-CM","UC-AUD","UC-DOC"], "standards": ["ISO9001","IATF16949","AS9100","ISO13485"], "data_objects": ["process","nonconformity","CAPA","inspection"]},
    {"module": "EHS (Environment, Health & Safety)", "domains": ["L10","L11","L17"], "controls": ["UC-ENV","UC-OHS"], "standards": ["ISO14001","ISO45001","ISO50001","ESRS"], "data_objects": ["hazard","aspect","permit","emission","incident"]},
    {"module": "IT Service Management", "domains": ["L6","L12","L16"], "controls": ["UC-CM","UC-IM","UC-AM"], "standards": ["ISO20000","ITIL","COBIT"], "data_objects": ["service","ticket","CI","change","SLA"]},
    {"module": "Information Security / Cyber", "domains": ["L12","L19"], "controls": ["UC-AC","UC-LOG","UC-CRYPTO","UC-VULN","UC-IM","UC-BCM"], "standards": ["ISO27001","NIST80053","SOC2","PCIDSS","CISV8","NIS2"], "data_objects": ["asset","vulnerability","log","incident","key"]},
    {"module": "Data Privacy", "domains": ["L13","L20"], "controls": ["UC-PM","UC-DG"], "standards": ["ISO27701","GDPR","PDPA_TH","PDPA_SG","CCPA","HIPAA"], "data_objects": ["RoPA","consent","DSAR","DPIA","data-subject"]},
    {"module": "AI / Model Governance", "domains": ["L14","L2"], "controls": ["UC-AIG","UC-RM"], "standards": ["ISO42001","NISTAIRMF","EUAIACT","OECDAI","OWASPLLM"], "data_objects": ["model","dataset","AIA","eval","deployment"]},
    {"module": "Risk Management", "domains": ["L2","L1"], "controls": ["UC-RM","UC-BCM"], "standards": ["ISO31000","COSOERM","NISTCSF"], "data_objects": ["risk","treatment","KRI","scenario"]},
    {"module": "Business Continuity / Resilience", "domains": ["L19","L6"], "controls": ["UC-BCM","UC-IM"], "standards": ["ISO22301","DORA","NISTCSF"], "data_objects": ["BIA","plan","test","RTO","RPO"]},
    {"module": "ESG / Sustainability", "domains": ["L17","L10","L1"], "controls": ["UC-ESG","UC-ENV"], "standards": ["ESRS","GRISTD","IFRSS1","IFRSS2","GHGP_CORP","CSRD","TNFDREC"], "data_objects": ["metric","disclosure","target","emission-factor","materiality"]},
    {"module": "Asset Management (EAM)", "domains": ["L7","L6"], "controls": ["UC-AM"], "standards": ["ISO55001","ISO27001"], "data_objects": ["asset","maintenance","lifecycle","valuation"]},
    {"module": "Customer / CRM & Accessibility", "domains": ["L8","L13"], "controls": ["UC-PM"], "standards": ["ISO9001","WCAG","GDPR"], "data_objects": ["customer","consent","case","feedback"]},
    {"module": "Audit & Assurance", "domains": ["L18","L3"], "controls": ["UC-AUD"], "standards": ["ISO19011","SOC2","SOX"], "data_objects": ["audit","finding","evidence","attestation"]}
  ]
